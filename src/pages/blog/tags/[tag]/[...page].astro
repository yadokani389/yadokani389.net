---
import type { CollectionEntry } from "astro:content";
import type { GetStaticPathsOptions, Page } from "astro";
import TagList from "../../../../components/TagList.svelte";
import Layout from "../../../../layouts/Layout.astro";
import {
  BLOG_TAGS_PAGE_SIZE,
  buildBlogTagIndex,
  getBlogPostsByTagName,
  getPublishedBlogPosts,
} from "../../../../lib/blog/tags";
import { formatDate } from "../../../../utils/formatDate";

interface Props {
  page: Page<CollectionEntry<"blog">>;
  tagName: string;
  totalPosts: number;
}

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getPublishedBlogPosts();
  const tags = buildBlogTagIndex(posts);

  return tags.flatMap((tag) =>
    paginate(getBlogPostsByTagName(posts, tag.name), {
      params: { tag: tag.slug },
      props: {
        tagName: tag.name,
        totalPosts: tag.count,
      },
      pageSize: BLOG_TAGS_PAGE_SIZE,
    }),
  );
}

const { page, tagName, totalPosts } = Astro.props as Props;
---

<Layout title={`Blog: #${tagName}`} description={`${tagName} の記事一覧`}>
  <div class="mx-auto flex max-w-5xl flex-col gap-10">
    <a
      class="inline-flex w-fit items-center gap-2 text-sm font-semibold text-ink-600 hover:text-sage-600"
      href="/blog"
    >
      ← Blogに戻る
    </a>

    <header class="space-y-3">
      <p class="text-sm font-semibold text-ink-500">タグ別アーカイブ</p>
      <h1 class="text-3xl font-display text-ink-900 md:text-4xl">#{tagName}</h1>
      <p class="text-sm text-ink-600">{totalPosts}件の記事</p>
    </header>

    <div class="grid gap-6">
      {
        page.data.map((post) => (
          <article
            class="group relative flex cursor-pointer flex-col gap-4 rounded-2xl border border-sand-200 bg-sand-50 p-6 transition hover:border-sage-500/40 hover:shadow-soft focus-within:ring-2 focus-within:ring-sage-500/40"
            data-card-link
            data-href={`/blog/${post.id}`}
            role="link"
            tabindex="0"
            aria-label={`${post.data.title} の記事へ移動`}
          >
            <div class="text-xs font-semibold text-ink-500">
              <span>{formatDate(post.data.date)}</span>
            </div>
            <div>
              <h2 class="text-xl font-display text-ink-900">
                {post.data.title}
              </h2>
              <p class="mt-2 text-sm leading-relaxed text-ink-600">
                {post.data.description}
              </p>
            </div>
            <div class="mt-2">
              <TagList tags={post.data.tags} basePath="/blog" />
            </div>
          </article>
        ))
      }
    </div>

    {
      page.lastPage > 1 && (
        <nav
          class="flex flex-wrap items-center justify-center gap-3 rounded-2xl border border-sand-200 bg-sand-50 px-4 py-3 text-sm font-semibold text-ink-700"
          aria-label="タグページのページネーション"
        >
          {page.url.prev ? (
            <a
              class="inline-flex items-center rounded-full border border-sand-200 px-3 py-1 transition hover:border-sage-500/40 hover:text-sage-700"
              href={page.url.prev}
              rel="prev"
            >
              ← 前へ
            </a>
          ) : (
            <span
              class="inline-flex items-center rounded-full border border-sand-200 px-3 py-1 text-ink-400"
              aria-disabled="true"
            >
              ← 前へ
            </span>
          )}

          <span class="px-2 text-xs text-ink-500">
            {page.currentPage} / {page.lastPage}
          </span>

          {page.url.next ? (
            <a
              class="inline-flex items-center rounded-full border border-sand-200 px-3 py-1 transition hover:border-sage-500/40 hover:text-sage-700"
              href={page.url.next}
              rel="next"
            >
              次へ →
            </a>
          ) : (
            <span
              class="inline-flex items-center rounded-full border border-sand-200 px-3 py-1 text-ink-400"
              aria-disabled="true"
            >
              次へ →
            </span>
          )}
        </nav>
      )
    }
  </div>
</Layout>
