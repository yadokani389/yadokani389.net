---
import { getCollection, getEntry, render } from "astro:content";
import ArticleDetailShell from "../../components/article/ArticleDetailShell.astro";

export async function getStaticPaths() {
  const works = await getCollection("works");
  return works.map((work) => ({ params: { slug: work.id } }));
}

const { slug } = Astro.params;
const work = await getEntry("works", slug);
if (!work) {
  throw new Error(`Work not found: ${slug}`);
}
const { Content } = await render(work);
---

<ArticleDetailShell
  title={work.data.title}
  description={work.data.description}
  date={work.data.date}
  lastmod={work.data.lastmod}
  tags={work.data.tags ?? []}
  tagBasePath="/works"
  backHref="/works"
  backLabel="← Worksに戻る"
  searchType="works"
  searchLabel="Works"
>
  <Content />
</ArticleDetailShell>
